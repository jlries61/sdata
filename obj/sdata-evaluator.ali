W ada.numerics.elementary_functions%s  a-nuelfu.ads  a-nuelfu.ali
Z ada.strings.text_buffers%s  a-sttebu.adb	a-sttebu.ali
Z ada.tags%s		a-tags.adb		a-tags.ali
W ada.text_io%s		a-textio.adb		a-textio.ali
W sdata%s		sdata.ads		sdata.ali
W sdata.statistics%s	sdata-statistics.adb	sdata-statistics.ali
W sdata.table%s		sdata-table.adb		sdata-table.ali
W sdata.variables%s	sdata-variables.adb	sdata-variables.ali
Z system.concat_3%s	s-conca3.adb		s-conca3.ali
Z system.fat_flt%s	s-fatflt.ads		s-fatflt.ali
Z system.secondary_stack%s  s-secsta.adb	s-secsta.ali

U sdata.evaluator%s	sdata-evaluator.ads	469f5f50 EE NE OO PK
