#!/usr/bin/make -f
export DH_VERBOSE = 1

# Bundled sdata-core version (path-pin sibling during development).
# Keep in sync with SDATA_CORE_VERSION in the parent Makefile.
SDATA_CORE_VERSION = 0.1.0

# Point gprbuild at the vendored dependency subdirectories for all phases (build, test, clean).
# sdata-core's .gpr lives at the root of its unpacked tarball; mathpaqs uses
# its standalone variant in the packaged build (see config/sdata_core_config.gpr
# injected into the sdata-core tarball by the parent Makefile).
export GPR_PROJECT_PATH=$(CURDIR)/zipada_61.0.0_54fc9836:$(CURDIR)/xmlada_26.0.0_b140ed4a/dom:$(CURDIR)/xmlada_26.0.0_b140ed4a/input_sources:$(CURDIR)/mathpaqs_20260205.0.0_abed7ef9:$(CURDIR)/ada_sqlite3_0.1.1_2edbcebd:$(CURDIR)/sdata-core-$(SDATA_CORE_VERSION)

%:
	dh $@

override_dh_auto_build:
	# Suppress strict style checks in the ada_sqlite3 dependency (same patch
	# the RPM spec applies).
	sed -i 's/"-gnaty.*"/"-gnatws"/g' $(CURDIR)/ada_sqlite3_0.1.1_2edbcebd/config/ada_sqlite3_config.gpr
	sed -i 's/"-gnatwa"/"-gnatws"/g' $(CURDIR)/ada_sqlite3_0.1.1_2edbcebd/config/ada_sqlite3_config.gpr
	make build

override_dh_auto_install:
	make install DESTDIR=$(CURDIR)/debian/sdata PREFIX=/usr DOCDIR=/usr/share/doc/sdata
