NEW
REPEAT 5
SELECT (RECNO())
  CASE (1) LET G = 100
  CASE (2, 3) LET G = 200
  OTHERWISE LET G = 300
END
PRINT RECNO() G
RUN

NEW
REPEAT 5
IF RECNO() = 3 THEN DELETE
PRINT RECNO()
RUN

NEW
REPEAT 5
SELECT
  WHEN (RECNO() < 3) LET TYPE$ = "SMALL"
  WHEN (RECNO() = 3) LET TYPE$ = "MEDIUM"
  OTHERWISE LET TYPE$ = "LARGE"
END
PRINT RECNO() TYPE$
RUN
